{
    "name": "digital-isp/radius-service",
    "description": "RADIUS Service Enhancement for Digital ISP ERP System",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.1",
        "ext-curl": "*",
        "ext-gd": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "ext-pdo": "*",
        "ext-pdo_mysql": "*",
        "ext-redis": "*",
        "ext-sqlite3": "*",
        "ext-zip": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.10",
        "roave/security-advisories": "dev-latest",
        "mockery/mockery": "^1.6",
        "fakerphp/faker": "^1.23"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        },
        "files": [
            "config/app.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "php artisan test",
        "test:coverage": "php artisan test --coverage-text --coverage-html=coverage",
        "analyse": "phpstan analyse app --level=5",
        "security": "composer audit",
        "lint": "php-cs-fixer fix --dry-run --diff",
        "format": "php-cs-fixer fix"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}