# ============================================================
# Digital ISP ERP — Environment Configuration Template
# Copy this file to .env and fill in your values
# ============================================================

# ── Application ───────────────────────────────────────────────
APP_NAME="DIGITAL ISP ERP"
APP_URL=http://localhost:8000
APP_ENV=local
APP_DEBUG=true
APP_TIMEZONE=Asia/Dhaka
APP_KEY=base64:REPLACE_WITH_RANDOM_BASE64_KEY

# ── Database ──────────────────────────────────────────────────
# Use sqlite for local dev, mysql for staging/production
DB_CONNECTION=sqlite
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=database/digital_isp.sqlite
DB_USERNAME=root
DB_PASSWORD=

# ── RADIUS Database (FreeRADIUS) ──────────────────────────────
RADIUS_HOST=127.0.0.1
RADIUS_PORT=1812
RADIUS_DB_CONNECTION=mysql
RADIUS_DB_HOST=127.0.0.1
RADIUS_DB_PORT=3306
RADIUS_DB_DATABASE=radius
RADIUS_DB_USERNAME=root
RADIUS_DB_PASSWORD=

# ── JWT (API Authentication) ──────────────────────────────────
JWT_SECRET=REPLACE_WITH_RANDOM_SECRET_MIN_32_CHARS
JWT_EXPIRY=86400

# ── SMS Gateway ───────────────────────────────────────────────
# Supported: sslwireless, bulksmsbd
SMS_GATEWAY=sslwireless
SMS_API_KEY=
SMS_SENDER_ID=DIGITALISP

# ── MikroTik ──────────────────────────────────────────────────
MIKROTIK_TIMEOUT=10

# ── Email ─────────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@digitalisp.xyz

# ── PipraPay / PayBill ────────────────────────────────────────
PAYBILL_DB_HOST=localhost
PAYBILL_DB_PORT=3306
PAYBILL_DB_NAME=piprapay
PAYBILL_DB_USERNAME=root
PAYBILL_DB_PASSWORD=
PAYBILL_DB_PREFIX=pp_

# ── Backups ───────────────────────────────────────────────────
BACKUP_KEEP_DAYS=30
BACKUP_MAX_COUNT=60

# ── AI Assistant (LM Studio / OpenAI-compatible) ──────────────
AI_ENABLED=true
AI_BASE_URL=http://localhost:1234/v1
AI_MODEL=google/gemma-4-e4b
AI_TIMEOUT=30
