# ============================================================
# FCN ISP ERP — Environment Configuration Template
# Copy this file to .env and fill in your values
# ============================================================

# ── Application ───────────────────────────────────────────────

# Application display name shown in the UI.
APP_NAME="FCN ISP ERP"

# Full public URL of the application (no trailing slash). Used for generating links.
APP_URL=http://10.10.10.42:8081

# Environment: local | staging | production
APP_ENV=local

# Must be false in production. Set to true only for local development.
APP_DEBUG=true

# Timezone used by date_default_timezone_set() on startup. See: https://www.php.net/manual/en/timezones.php
APP_TIMEZONE=Asia/Dhaka

# Application encryption key. Generate with: php -r "echo 'base64:'.base64_encode(random_bytes(32)).PHP_EOL;"
APP_KEY=base64:REPLACE_WITH_RANDOM_BASE64_KEY

# ── Database ──────────────────────────────────────────────────

# Database driver: sqlite (local dev) | mysql (staging/production)
DB_CONNECTION=sqlite

# Database server hostname or IP address. Not used when DB_CONNECTION=sqlite.
DB_HOST=127.0.0.1

# Database server port. Default MySQL port is 3306.
DB_PORT=3306

# For sqlite: relative path to the .sqlite file (e.g. database/digital_isp.sqlite).
# For mysql: the database schema name.
DB_DATABASE=database/digital_isp.sqlite

# Database username. Use a dedicated application user in production (not root).
DB_USERNAME=root

# Database password. Use a strong password in production.
DB_PASSWORD=REPLACE_WITH_DB_PASSWORD

# ── RADIUS Database (FreeRADIUS) ──────────────────────────────

# Hostname or IP of the FreeRADIUS server.
RADIUS_HOST=127.0.0.1

# FreeRADIUS authentication port (default: 1812).
RADIUS_PORT=1812

# Database driver for the RADIUS database: mysql | sqlite
RADIUS_DB_CONNECTION=mysql

# Hostname or IP of the RADIUS MySQL database server.
RADIUS_DB_HOST=127.0.0.1

# Port of the RADIUS MySQL database server.
RADIUS_DB_PORT=3306

# RADIUS database schema name.
RADIUS_DB_DATABASE=radius

# RADIUS database username.
RADIUS_DB_USERNAME=root

# RADIUS database password. Use a strong password in production.
RADIUS_DB_PASSWORD=REPLACE_WITH_RADIUS_DB_PASSWORD

# ── JWT (API Authentication) ──────────────────────────────────

# JWT signing secret. Minimum 32 characters. Generate with: openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_RANDOM_SECRET_MIN_32_CHARS

# JWT token expiry in seconds (default: 86400 = 24 hours).
JWT_EXPIRY=86400

# ── CORS (Cross-Origin Resource Sharing) ───────────────────

# Comma-separated list of allowed origins for API access (no spaces)
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:3000,http://127.0.0.1

# ── SMS Gateway ───────────────────────────────────────────────

# Supported SMS gateway provider: sslwireless | bulksmsbd
SMS_GATEWAY=sslwireless

# API key for the configured SMS gateway provider.
SMS_API_KEY=REPLACE_WITH_SMS_API_KEY

# Sender ID displayed on outgoing SMS messages (must be approved by the gateway).
SMS_SENDER_ID=DIGITALISP

# ── MikroTik ──────────────────────────────────────────────────

# Connection timeout in seconds for MikroTik API calls.
MIKROTIK_TIMEOUT=10

# ── Email ─────────────────────────────────────────────────────

# SMTP server hostname for outgoing email.
MAIL_HOST=smtp.gmail.com

# SMTP server port (587 for STARTTLS, 465 for SSL, 25 for plain).
MAIL_PORT=587

# SMTP authentication username (usually the sender email address).
MAIL_USERNAME=REPLACE_WITH_MAIL_USERNAME

# SMTP authentication password or app-specific password.
MAIL_PASSWORD=REPLACE_WITH_MAIL_PASSWORD

# From address used on all outgoing emails.
MAIL_FROM=noreply@digitalisp.xyz

# ── PipraPay / PayBill ────────────────────────────────────────

# Hostname or IP of the PipraPay database server.
PAYBILL_DB_HOST=localhost

# Port of the PipraPay database server.
PAYBILL_DB_PORT=3306

# PipraPay database schema name.
PAYBILL_DB_NAME=piprapay

# PipraPay database username.
PAYBILL_DB_USERNAME=root

# PipraPay database password. Use a strong password in production.
PAYBILL_DB_PASSWORD=REPLACE_WITH_PAYBILL_DB_PASSWORD

# Table prefix used for all PipraPay tables.
PAYBILL_DB_PREFIX=pp_

# ── Backups ───────────────────────────────────────────────────

# Number of days to retain backup files before deletion.
BACKUP_KEEP_DAYS=30

# Maximum number of backup files to keep regardless of age.
BACKUP_MAX_COUNT=60

# ── AI Assistant (LM Studio / OpenAI-compatible) ──────────────

# Enable or disable the AI assistant feature: true | false
AI_ENABLED=true

# Base URL of the OpenAI-compatible API endpoint (e.g. LM Studio local server).
AI_BASE_URL=http://localhost:1234/v1

# Model identifier to use for AI completions (must be loaded in the AI server).
AI_MODEL=google/gemma-4-e4b

# Request timeout in seconds for AI API calls.
AI_TIMEOUT=30
